generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // Uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // Uses direct connection
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatar        String?
  password      String? // Hashed password for credential login
  
  // Progress Data
  totalXp       Int       @default(0)
  level         Int       @default(1)
  hearts        Int       @default(5)
  streak        Int       @default(0)
  lastActiveDate DateTime? // Stored as actual DateTime

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  memory        UserMemory?
}

model UserMemory {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  hobbies     String?  @db.Text
  weaknesses  String?  @db.Text
  profession  String?
  goals       String?
  notes       String?  @db.Text // AI's general notes about the user

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
